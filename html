<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Interior Design Studio</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      line-height: 1.6;
    }

    header {
      background: rgba(0, 0, 0, 0.7);
      color: white;
      padding: 15px 0;
      position: fixed;
      width: 100%;
      z-index: 1000;
    }

    nav {
      display: flex;
      justify-content: space-between;
      width: 90%;
      margin: auto;
      align-items: center;
    }

    nav ul {
      list-style: none;
      display: flex;
    }

    nav ul li {
      margin-left: 20px;
    }

    nav ul li a {
      color: white;
      text-decoration: none;
      cursor: pointer;
    }

    .hero {
      height: 100vh;
      background: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c') no-repeat center center/cover;
      display: flex;
      justify-content: center;
      align-items: center;
      color: white;
      text-align: center;
    }

    .hero h1 {
      font-size: 50px;
      background: rgba(0, 0, 0, 0.5);
      padding: 20px;
    }

    section {
      padding: 80px 20px;
      text-align: center;
    }

    .about {
      background: #f4f4f4;
    }

    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
      padding: 20px;
    }
    .us{
      background-color: rgb(188, 112, 14);
    }
  .p1{
    background-color: blue;
    }

    .gallery img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      border-radius: 10px;
      transition: transform 0.3s;
    }

    .gallery img:hover {
      transform: scale(1.05);
    }

    .contact form {
      max-width: 500px;
      margin: auto;
    }

    .contact input,
    .contact textarea {
      width: 100%;
      padding: 10px;
      margin: 10px 0;
    }

    .contact button {
      padding: 10px 20px;
      background: black;
      color: white;
      border: none;
      cursor: pointer;
    }

    footer {
      background: black;
      color: white;
      padding: 15px;
      text-align: center;
    }
  </style>
</head>

<body>

  <header>
    <nav>
      <h2>GR Choudhary Construction</h2>
      <ul>
        <li><a onclick="scrollToSection('home')">Home</a></li>
        <li><a onclick="scrollToSection('about')">About</a></li>
        <li><a onclick="scrollToSection('gallery')">Gallery</a></li>
        <li><a onclick="scrollToSection('contact')">Contact</a></li>
      </ul>
    </nav>
  </header>

  <section id="home" class="hero">
    <h1>Design Your Dream Space</h1>
  </section>

  <section id="about" class="about">
    <h2>About Us</h2>
    
    
    <p1 >
      CHAIRMAN :- GOVINDRAM CHOUDHARY
     </br>
     CONTACT:- +918806088162 ,+918999326734
      </br>  </br> 
      CEO :- PRADEEP CHOUDHARY
       </br>
       CONTACT:- +918239745399
       <p1> </br></br>
      We create modern and elegant interior designs that transform your space into a dream home.
      Our team specializes in residential and commercial interiors with a focus on beauty and comfort.
      </br>
      </br>
      Tiles, Marble, Granite and Italian-stone fitting.



    </p>
    

        

    </p1>
  </section>
  

  <section id="gallery">
    <h2>Our Designs</h2>
    <div class="gallery">
      <img src="https://images.unsplash.com/photo-1505691938895-1758d7feb511">
      <img src="https://images.unsplash.com/photo-1493666438817-866a91353ca9">
      <img src="https://images.unsplash.com/photo-1507089947368-19c1da9775ae">
      <img src="https://images.unsplash.com/photo-1493809842364-78817add7ffb">
      <img src="https://images.unsplash.com/photo-1484154218962-a197022b5858">
      <img src="https://images.unsplash.com/photo-1502005229762-cf1b2da7c5d6">
    </div>
  </section>

  <section id="contact" class="contact">
    <h2>Contact Us</h2>
    <form onsubmit="submitForm(event)">
      <input type="text" placeholder="Your Name" required="">
      <input type="email" placeholder="Your Email" required="">
      <textarea rows="5" placeholder="Your Message" required=""></textarea>
      <button type="submit">Send Message</button>
    </form>
    <p id="message"></p>
  </section>

  <footer>
    <p>© 2026 Interior Design Studio</p>
  </footer>

  <script>
    function scrollToSection(id) {
      document.getElementById(id).scrollIntoView({
        behavior: "smooth"
      });
    }

    function submitForm(event) {
      event.preventDefault();
      document.getElementById("message").innerText = "Message sent successfully!";
    }
  </script>


</body>

</html>
